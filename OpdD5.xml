              id="d0e269">
            <witList TEIform="witList">
               <witness sigil="OpdM1 " n="OpdM1" TEIform="witness">1934: eerste typoscript 'Inleiding'</witness>
               <witness sigil="OpdM2 " n="OpdM2" TEIform="witness">1934: tweede typoscript 'Inleiding'</witness>
               <witness sigil="OpdT1 " n="OpdT1" TEIform="witness">1934: Tsjip, voorpublicatie in Forum</witness>
               <witness sigil="OpdD1 " n="OpdD1" TEIform="witness">1934: Tsjip, eerste druk</witness>
               <witness sigil="OpdD2 " n="OpdD2" TEIform="witness">1936: Tsjip, tweede druk</witness>
               <witness sigil="OpdD3 " n="OpdD3" TEIform="witness">1942: Tsjip, derde druk</witness>
               <witness sigil="OpdD4 " n="OpdD4" TEIform="witness">1943: Tsjip/De Leeuwentemmer, eerste druk</witness>
               <witness sigil="OpdD5 " n="OpdD5" TEIform="witness">1944: Tsjip/De Leeuwentemmer, tweede druk</witness>
               <witness sigil="OpdD6 " n="OpdD6" TEIform="witness">1952: Tsjip/De Leeuwentemmer, derde druk</witness>
               <witness sigil="OpdP1a " n="OpdP1a" TEIform="witness">1956-57: Tsjip/De Leeuwentemmer, eerste drukproef voor het Verzameld Werk, getypte tekst</witness>
               <witness sigil="OpdP1b " n="OpdP1b" TEIform="witness">1956-57: Tsjip/De Leeuwentemmer, eerste drukproef voor het Verzameld Werk, zwarte inkt</witness>
               <witness sigil="OpdP2 " n="OpdP2" TEIform="witness">1957: Tsjip/De Leeuwentemmer, tweede drukproef voor het Verzameld Werk</witness>
               <witness sigil="OpdD7 " n="OpdD7" TEIform="witness">1957: Tsjip/De Leeuwentemmer, vierde druk, in het Verzameld Werk</witness>
